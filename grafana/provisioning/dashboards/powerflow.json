{
  "id": null,
  "uid": "powerflow-dashboard",
  "title": "PowerFlow - Production Line Dashboard",
  "tags": ["powerflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Products Produced Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
          "query": "from(bucket: \"powerflow\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"production\")\n  |> filter(fn: (r) => r._field == \"products_produced\")\n  |> filter(fn: (r) => r.line == \"powerflow\")",
          "hide": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Defective Products Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
          "query": "from(bucket: \"powerflow\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"production\")\n  |> filter(fn: (r) => r._field == \"defective_products\")\n  |> filter(fn: (r) => r.line == \"powerflow\")",
          "hide": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Current Machine State",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "IDLE", "color": "gray" },
                "1": { "text": "RUNNING", "color": "green" },
                "2": { "text": "STOPPED", "color": "orange" },
                "3": { "text": "FAULT", "color": "red" }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "powerflow-influxdb-ds" },
          "query": "from(bucket: \"powerflow\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"production\")\n  |> filter(fn: (r) => r._field == \"state_code\")\n  |> last()",
          "hide": false
        }
      ]
    }
  ]
}